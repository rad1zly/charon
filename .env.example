# ── Telegram (required) ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TOPIC_ID=

# ── Signal server (required — contact maintainer for access) ────────
SIGNAL_SERVER_URL=https://api.thecharon.xyz/api
SIGNAL_SERVER_KEY=
SIGNAL_POLL_MS=30000

# ── Solana RPC — required for live execution; free tier works for dry_run
HELIUS_API_KEY=
SOLANA_RPC_URL=
SOLANA_WS_URL=

# ── GMGN enrichment — set GMGN_ENABLED=false to skip (falls back to Jupiter data)
GMGN_ENABLED=true
GMGN_API_KEY=
GMGN_REQUEST_DELAY_MS=2500
GMGN_MAX_RETRIES=2

# ── Storage & mode ───────────────────────────────────────────────────
DB_PATH=./charon.sqlite
TRADING_MODE=dry_run

# ── Live / confirm execution — wallet + Jupiter API key required ─────
SOLANA_PRIVATE_KEY=
JUPITER_API_KEY=
JUPITER_SWAP_BASE_URL=https://api.jup.ag/swap/v2
LIVE_MIN_SOL_RESERVE=0.02

# ── Web dashboard ────────────────────────────────────────────────────
# Bound to 127.0.0.1 by default. On a VPS either keep it local and use an
# SSH tunnel (ssh -L 8787:127.0.0.1:8787 user@vps), or set
# DASHBOARD_HOST=0.0.0.0 AND a strong DASHBOARD_TOKEN.
DASHBOARD_ENABLED=true
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8787
DASHBOARD_TOKEN=

# ── Screening (rule engine — no LLM) ────────────────────────────────
BATCH_PICK_COUNT=10
CANDIDATE_MAX_AGE_MS=600000
MAX_OPEN_POSITIONS=3
MIN_FEE_CLAIM_SOL=2

# ── Signal polling / trending ────────────────────────────────────────
GRADUATED_POLL_MS=30000
GRADUATED_LOOKBACK_MS=7200000
TRENDING_POLL_MS=60000
TRENDING_LOOKBACK_MS=600000
TRENDING_ENABLED=true
TRENDING_SOURCE=jupiter
TRENDING_ALLOW_DEGEN=false
TRENDING_INTERVAL=5m
TRENDING_LIMIT=100
TRENDING_ORDER_BY=volume
TRENDING_MIN_VOLUME_USD=0
TRENDING_MIN_SWAPS=0
TRENDING_MAX_RUG_RATIO=0.3
TRENDING_MAX_BUNDLER_RATE=0.5
GMGN_CACHE_TTL_MS=300000
POSITION_CHECK_MS=10000
